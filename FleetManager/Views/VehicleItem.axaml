<!-- (UserControl - widok) -->

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="FleetManager.Views.VehicleItem"
             Margin="10">
                <Border
                    BorderBrush="#222222"
                    BorderThickness="3"
                    CornerRadius="10"
                    BoxShadow="12 12 25 #313131"
                    Background="#A46974"
                    >
                    <Grid RowDefinitions="* * * *" ColumnDefinitions="*" VerticalAlignment="Center" Margin="10">
                        <TextBlock Grid.Row="0"
                                   Text="[Nazwa pojazdu]"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Padding="0"
                                   Margin="10"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                        />
                        <TextBlock Grid.Row="1"
                                   Text="[Numer rejestracyjny]"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Padding="0"
                                   Margin="10"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                        />
                        <TextBlock Grid.Row="2"
                                   Text="[Poziom paliwa %]"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Padding="0"
                                   Margin="10"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                        />
                        <TextBlock Grid.Row="3"
                                   Text="[Status]"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Padding="0"
                                   Margin="10"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   />
                    </Grid>
                </Border>
</UserControl>